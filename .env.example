# ===================================================
# Moss Nexus - Environment Configuration
# 이 파일을 복사하여 .env 파일을 생성하세요
# cp .env.example .env
# ===================================================

# Discord Bot Token
# Discord Developer Portal에서 발급받은 봇 토큰
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Ollama Configuration
# Ollama 서버 주소 (로컬 실행 시 기본값 사용)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3:70b

# Qdrant Configuration
# Qdrant Vector DB 설정
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=moss_knowledge

# Embedding Model Configuration
# HuggingFace 임베딩 모델 설정
EMBEDDING_MODEL=BAAI/bge-m3

# Data Directory
# 문서 파일이 저장된 디렉토리 경로
DATA_DIR=./data

# Chunking Configuration
# 문서 분할 설정
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Retrieval Configuration
# 검색 설정
TOP_K_RESULTS=4

# FastAPI Configuration
# API 서버 설정
API_HOST=0.0.0.0
API_PORT=8000

# Logging
# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
